{
    "version": 2,
    "framework": null,
    "buildCommand": "npm run build",
    "outputDirectory": "public",
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.9.0"
        }
    },
    "routes": [
        { "src": "/", "dest": "/api/index.php" },
        { "src": "/index\\.php", "dest": "/api/index.php" },
        { "src": "/\\.htaccess", "dest": "/api/index.php" },
        { "handle": "filesystem" },
        { "src": "/(.*)", "dest": "/api/index.php" }
    ]
}
